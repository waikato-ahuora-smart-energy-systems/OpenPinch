{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Main Debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Specific Test",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}", 
            "args": [
            //   "-s",
            //   "tests/test_classes/test_simple_heat_pump_cycle.py",
              "tests/test_classes/test_cascade_heat_pump_cycle.py",
            //   "tests/test_utils/test_optimiser_benchmarks.py",
              "tests/test_utils/test_optimiser_handles.py",
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },   
        {
            "name": "e2e Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}/tests/", 
            "args": [
              "e2e",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },    
        {
            "name": "All tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}/tests/", 
            "args": [
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },                
    ]
}
